# ═══════════════════════════════════════════════════════════
# ShipFlow AI — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL via Docker) ─────────────────────
DATABASE_URL=postgresql://shipflow:shipflow_secret@localhost:5432/shipflow

# ── BetterAuth ───────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# ── GitHub OAuth App (for user login) ────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub App (for repo access + webhooks) ──────────────
GITHUB_APP_NAME=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── AI / OpenRouter ─────────────────────────────────────
OPENROUTER_API_KEY=

# ── Pinecone (optional — for vector-based repo context) ──
PINECONE_API_KEY=
PINECONE_INDEX=

# ── Razorpay (billing) ──────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# ── Inngest ──────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set to 1 when using the local Inngest dev server
INNGEST_DEV=1
