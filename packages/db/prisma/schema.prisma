// ─────────────────────────────────────────────────────────────────────────────
// ShipFlow AI — Prisma Schema
// Covers: Auth (BetterAuth), Multi-tenant Workspaces, Projects, Feature
// Requests, PRDs, Tasks, GitHub Integration, AI Reviews, and Billing.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH (BetterAuth)
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions           Session[]
  accounts           Account[]
  workspaceMembers   WorkspaceMember[]
  githubInstallation GithubInstallation?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // BetterAuth organization fields
  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-TENANT WORKSPACES
// ═══════════════════════════════════════════════════════════════════════════════

/// A workspace is the top-level tenant. Maps to BetterAuth "organization".
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Billing
  plan                   String  @default("free") // "free" | "pro" | "enterprise"
  razorpaySubscriptionId String?
  razorpayCustomerId     String?
  subscriptionStatus     String? // "active" | "cancelled" | "past_due"
  subscriptionRenewsAt   DateTime?
  aiReviewCredits        Int     @default(5) // monthly AI review credit limit
  repoLimit              Int     @default(3) // max connected repos

  // Relations
  members  WorkspaceMember[]
  projects Project[]

  @@map("workspace")
}

/// Join table linking users to workspaces with roles.
model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("member") // "owner" | "admin" | "member"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("workspace_member")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROJECTS & GITHUB
// ═══════════════════════════════════════════════════════════════════════════════

/// A project belongs to a workspace and optionally connects to a GitHub repo.
model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // GitHub connection
  repoFullName       String? // e.g. "owner/repo"
  githubInstallationId Int?   // GitHub App installation id

  // Relations
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]
  pullRequests    PullRequest[]
  repoSync        RepoSync?

  @@index([workspaceId])
  @@map("project")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FEATURE LIFECYCLE: Request → PRD → Tasks → Review → Ship
// ═══════════════════════════════════════════════════════════════════════════════

/// Feature request submitted by a product owner or user.
/// Status follows the state machine: new → clarifying → prd_generation →
/// prd_ready → planning → tasks_ready → in_development → ai_review →
/// fix_needed → human_review → shipped
model FeatureRequest {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String   @db.Text
  source      String   @default("manual") // "manual" | "email" | "support_ticket"
  status      String   @default("new")
  priority    String   @default("medium") // "low" | "medium" | "high" | "critical"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages ClarificationMessage[]
  prd      PRD?

  @@index([projectId])
  @@index([status])
  @@map("feature_request")
}

/// Conversation messages between the AI clarification agent and the user.
model ClarificationMessage {
  id               String   @id @default(cuid())
  featureRequestId String
  role             String   // "user" | "assistant"
  content          String   @db.Text
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@map("clarification_message")
}

/// Product Requirements Document generated by the AI agent.
model PRD {
  id                 String   @id @default(cuid())
  featureRequestId   String   @unique
  problemStatement   String   @db.Text
  goals              Json     // string[]
  nonGoals           Json     // string[]
  userStories        Json     // { as: string, iWant: string, soThat: string }[]
  acceptanceCriteria Json     // string[]
  edgeCases          Json     // string[]
  successMetrics     Json     // string[]
  rawMarkdown        String?  @db.Text // full PRD as editable markdown
  status             String   @default("draft") // "draft" | "approved" | "revision_needed"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@map("prd")
}

/// Engineering task derived from a PRD.
/// Displayed on the Kanban board.
model Task {
  id          String   @id @default(cuid())
  prdId       String
  title       String
  description String   @db.Text
  status      String   @default("todo") // "todo" | "in_progress" | "review" | "done"
  priority    String   @default("medium") // "low" | "medium" | "high"
  order       Int      @default(0)        // display order within column
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  prd PRD @relation(fields: [prdId], references: [id], onDelete: Cascade)

  @@index([prdId])
  @@index([status])
  @@map("task")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PULL REQUESTS & AI REVIEWS
// ═══════════════════════════════════════════════════════════════════════════════

/// One row per PR tracked by the platform.
model PullRequest {
  id             String    @id @default(cuid())
  projectId      String
  installationId Int
  repoFullName   String
  prNumber       Int
  title          String
  authorLogin    String?
  headSha        String
  baseBranch     String
  status         String    @default("pending") // "pending" | "processing" | "reviewed" | "fix_needed" | "approved" | "shipped"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@unique([repoFullName, prNumber])
  @@index([projectId])
  @@map("pull_request")
}

/// An individual AI review on a pull request.
model Review {
  id            String   @id @default(cuid())
  pullRequestId String
  reviewType    String   @default("ai") // "ai" | "human"
  status        String   @default("pending") // "pending" | "processing" | "completed"
  summary       String?  @db.Text
  markdown      String?  @db.Text // full review as markdown
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  pullRequest PullRequest  @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  issues      ReviewIssue[]

  @@index([pullRequestId])
  @@map("review")
}

/// Individual issue found during a review.
model ReviewIssue {
  id          String   @id @default(cuid())
  reviewId    String
  severity    String   // "blocking" | "non_blocking" | "suggestion"
  category    String   // "prd_compliance" | "security" | "performance" | "code_quality" | "edge_case"
  title       String
  description String   @db.Text
  filePath    String?
  lineNumber  Int?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_issue")
}

// ═══════════════════════════════════════════════════════════════════════════════
// HUMAN APPROVAL & RELEASE
// ═══════════════════════════════════════════════════════════════════════════════

/// Tracks the final human approval decision for a feature request.
model Release {
  id               String   @id @default(cuid())
  featureRequestId String   @unique
  approvedBy       String?  // userId of the human reviewer
  status           String   @default("pending") // "pending" | "approved" | "rejected"
  notes            String?  @db.Text
  decidedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("release")
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPO SYNC (Optional — Pinecone vector context)
// ═══════════════════════════════════════════════════════════════════════════════

model RepoSync {
  id             String    @id @default(cuid())
  projectId      String    @unique
  installationId Int
  repoFullName   String
  branch         String
  status         String    @default("pending") // "pending" | "syncing" | "synced" | "failed"
  chunkCount     Int       @default(0)
  syncedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("repo_sync")
}

model GithubInstallation {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  installationId Int // GitHub's numeric installation id
  accountLogin   String?
  accountType    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("github_installation")
}
